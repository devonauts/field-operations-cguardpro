<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Android 15+ overlay of AppTheme.NoActionBar (keep in sync with values/styles.xml).
         Targeting SDK 35 force-enables edge-to-edge, which draws the Capacitor WebView
         under the status/navigation bars; windowOptOutEdgeToEdge restores the framed
         layout the app is designed for. -->
    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <item name="android:windowOptOutEdgeToEdgeEnforcement">true</item>
    </style>
</resources>
