<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>NSCameraUsageDescription</key>
	<string>CGuardPro usa la cámara para escanear códigos QR de puntos de control y tomar fotos de evidencia y documentos.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>CGuardPro usa tu ubicación para validar el registro de entrada, los puntos de ronda y los incidentes.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>CGuardPro usa tu galería para adjuntar fotos a visitas, incidentes y puntos de control.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>CGuardPro puede guardar imágenes generadas (como códigos QR) en tu galería.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>CGuardPro usa el micrófono para dictar por voz el reporte de salida del turno.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>CGuardPro usa el reconocimiento de voz para convertir tu dictado en texto en el reporte de salida.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
		<string>audio</string>
	</array>
	<key>CFBundleDisplayName</key>
        <string>CGuardPro</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UIRequiresFullScreen</key>
	<true/>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.cguardpro.operaciones</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>cguardpro</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
