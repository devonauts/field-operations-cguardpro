{
  "name": "cguardpro-worker-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "CGuardPro field app for security guards and supervisors (Ionic + Capacitor).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "assets": "node scripts/gen-assets.cjs && capacitor-assets generate --iconBackgroundColor '#0A0E16' --iconBackgroundColorDark '#0A0E16' --splashBackgroundColor '#0A0E16' --splashBackgroundColorDark '#0A0E16'",
    "mobile": "vite build && LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 cap sync",
    "cap:sync": "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 cap sync",
    "cap:ios": "cap open ios",
    "cap:android": "cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.2",
    "@capacitor/camera": "^6.1.3",
    "@capacitor/core": "^6.1.2",
    "@capacitor/device": "^6.0.3",
    "@capacitor/geolocation": "^6.0.1",
    "@capacitor/haptics": "^6.0.2",
    "@capacitor/ios": "^6.2.1",
    "@capacitor/keyboard": "^6.0.3",
    "@capacitor/push-notifications": "^6.0.5",
    "@capacitor/splash-screen": "^6.0.4",
    "@capacitor/status-bar": "^6.0.2",
    "@ionic/react": "^8.4.0",
    "@ionic/react-router": "^8.4.0",
    "date-fns": "^4.1.0",
    "html5-qrcode": "^2.3.8",
    "i18next": "^23.16.8",
    "i18next-browser-languagedetector": "^8.0.2",
    "ionicons": "^7.4.0",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.2.0",
    "react-router": "^5.3.4",
    "react-router-dom": "^5.3.4",
    "recharts": "^2.15.0",
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.1.2",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-router": "^5.1.20",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
