      "punctuality": "Measures how many shifts you started on time and your average lateness.",
      "uniform": "Average of the uniform checks across your shifts.",
      "inventory": "Share of shifts with complete, verified inventory.",
      "consignas": "Station standing orders completed out of those assigned.",
      "rondas": "Patrols completed on time out of those scheduled.",
      "quiz": "Average of your station security tests.",
      "training": "Assigned training courses you completed."
    },
    "glossary": {
      "punctuality": "Punctuality rises when you start your shifts on time; late arrivals lower it and it weighs 18% of the base score.",
      "uniform": "Uniform reflects your presentation checks each shift and weighs 14% of the base score.",
      "inventory": "Inventory measures the shifts where you verified all assigned equipment and weighs 14% of the base score.",
      "consignas": "Standing orders measure the station tasks you completed out of those assigned and weigh 16% of the base score.",
      "rondas": "Patrols measure the rounds completed on time and weigh 16% of the base score.",
      "quiz": "The test takes the average of your station security tests and weighs 12% of the base score.",
      "training": "Training measures the assigned courses you completed and weighs 10% of the base score.",
      "penalty": "Absences and late arrivals apply a penalty to your base score: the more absences and late arrivals, the larger the deduction.",
      "bonus": "Backup adds a bonus when you volunteer for or cover other guards' shifts, up to a maximum cap."
    }
  },
